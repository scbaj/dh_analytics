<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>LAK 2026 — Batter At-Bat Viewer</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/pako/2.1.0/pako.min.js"></script>
<style>
@import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Mono:wght@300;400;500&family=Barlow:wght@300;400;500;600&family=Barlow+Condensed:wght@400;600;700&display=swap');

:root{
  --bg:#0b0d12;--surf:#111318;--surf2:#181c24;--border:#1e2330;
  --text:#dde2f0;--sub:#6a728a;--dim:#2e3448;
  --accent:#e8c84a;
  --ff:#ef4444;--si:#f97316;--ct:#eab308;--sl:#3b82f6;
  --cu:#a855f7;--ch:#22c55e;--sp:#06b6d4;--sw:#0097A7;
  --hit:#4ade80;--out:#6a728a;--k:#f87171;--bb:#60a5fa;--hr:#fbbf24;
}
*{box-sizing:border-box;margin:0;padding:0}
body{background:var(--bg);color:var(--text);font-family:'Barlow',sans-serif;height:100vh;overflow:hidden;display:flex;flex-direction:column}

/* ── HEADER ── */
header{
  padding:10px 20px;border-bottom:1px solid var(--border);
  display:flex;align-items:center;gap:16px;flex-shrink:0;
}
.logo{font-family:'Bebas Neue',sans-serif;font-size:1.4rem;letter-spacing:3px;color:var(--accent)}
.badge{font-family:'DM Mono',monospace;font-size:.6rem;background:#1a2744;color:var(--accent);border:1px solid #2d4a8a;padding:2px 8px;border-radius:3px;letter-spacing:.08em}
.hdr-right{margin-left:auto;font-family:'DM Mono',monospace;font-size:.6rem;color:var(--sub)}

/* ── LAYOUT ── */
.layout{display:flex;flex:1;overflow:hidden}

/* ── SIDEBAR ── */
.sidebar{width:190px;flex-shrink:0;background:var(--surf);border-right:1px solid var(--border);display:flex;flex-direction:column;overflow:hidden}
.sb-label{font-family:'DM Mono',monospace;font-size:.55rem;letter-spacing:.12em;text-transform:uppercase;color:var(--sub);padding:10px 12px 5px}
.batter-list{display:flex;flex-direction:column;gap:1px;padding:0 8px 8px;overflow-y:auto}
.batter-list::-webkit-scrollbar{width:2px}.batter-list::-webkit-scrollbar-thumb{background:var(--border)}
.bb{background:none;border:1px solid transparent;border-radius:4px;padding:5px 8px;color:var(--sub);font-family:'Barlow',sans-serif;font-size:.78rem;text-align:left;cursor:pointer;transition:all .12s;width:100%}
.bb:hover{background:rgba(232,200,74,.07);border-color:var(--border);color:var(--text)}
.bb.active{background:rgba(232,200,74,.12);border-color:var(--accent);color:var(--accent)}

/* ── MAIN ── */
.main{flex:1;display:flex;flex-direction:column;overflow:hidden}

/* ── GAME TABS ── */
.game-tabs{display:flex;gap:0;padding:8px 16px;border-bottom:1px solid var(--border);flex-shrink:0;overflow-x:auto;flex-wrap:nowrap}
.game-tabs::-webkit-scrollbar{height:2px}.game-tabs::-webkit-scrollbar-thumb{background:var(--border)}
.gt{background:none;border:1px solid var(--border);border-radius:4px;padding:4px 10px;margin-right:4px;color:var(--sub);font-family:'DM Mono',monospace;font-size:.62rem;letter-spacing:.04em;cursor:pointer;white-space:nowrap;transition:all .12s}
.gt:hover{color:var(--text);border-color:var(--sub)}
.gt.active{background:var(--surf2);color:var(--accent);border-color:var(--accent)}

/* ── AB GRID ── */
.ab-scroll{flex:1;overflow-y:auto;padding:14px 16px}
.ab-scroll::-webkit-scrollbar{width:4px}.ab-scroll::-webkit-scrollbar-thumb{background:var(--border);border-radius:2px}
.ab-grid{display:flex;flex-wrap:wrap;gap:14px;align-items:flex-start}

/* ── AB CARD ── */
.ab-card{
  background:var(--surf);border:1px solid var(--border);border-radius:8px;
  padding:10px;display:flex;flex-direction:column;gap:6px;
  width:170px;flex-shrink:0;transition:border-color .15s;
}
.ab-card:hover{border-color:var(--sub)}
.ab-card.result-hit{border-color:rgba(74,222,128,.3)}
.ab-card.result-hr{border-color:rgba(251,191,36,.5)}
.ab-card.result-k{border-color:rgba(248,113,113,.25)}
.ab-card.result-bb{border-color:rgba(96,165,250,.25)}

.ab-header{display:flex;align-items:center;justify-content:space-between}
.ab-inn{font-family:'DM Mono',monospace;font-size:.58rem;color:var(--sub)}
.ab-pc{font-family:'DM Mono',monospace;font-size:.58rem;color:var(--dim)}
.ab-pitcher{font-family:'Barlow',monospace;font-size:.6rem;color:var(--sub);margin-bottom:1px;display:flex;align-items:center;gap:4px}
.throws-R{color:#c084fc;font-size:.55rem;font-weight:600}
.throws-L{color:#60a5fa;font-size:.55rem;font-weight:600}

/* ── STRIKE ZONE CANVAS ── */
canvas.sz{display:block;border-radius:3px;cursor:crosshair}

/* ── RESULT CHIP ── */
.result-chip{
  display:flex;align-items:center;justify-content:center;gap:6px;
  padding:4px 6px;border-radius:4px;
  font-family:'Barlow Condensed',sans-serif;font-size:.78rem;font-weight:600;letter-spacing:.04em;
}
.result-chip.hit{background:rgba(74,222,128,.12);color:#4ade80;border:1px solid rgba(74,222,128,.2)}
.result-chip.hr{background:rgba(251,191,36,.15);color:#fbbf24;border:1px solid rgba(251,191,36,.25)}
.result-chip.k{background:rgba(248,113,113,.1);color:#f87171;border:1px solid rgba(248,113,113,.2)}
.result-chip.bb{background:rgba(96,165,250,.1);color:#60a5fa;border:1px solid rgba(96,165,250,.2)}
.result-chip.out{background:rgba(106,114,138,.1);color:#6a728a;border:1px solid rgba(106,114,138,.2)}

/* ── BIP STATS ── */
.bip-stats{display:flex;gap:6px;flex-wrap:wrap}
.bip-stat{
  font-family:'DM Mono',monospace;font-size:.57rem;
  background:var(--surf2);border:1px solid var(--border);
  padding:2px 5px;border-radius:3px;color:var(--sub);
}
.bip-stat b{color:var(--text);font-weight:500}
.bip-stat.ev-hot b{color:#f97316}
.bip-stat.ev-warm b{color:#eab308}

/* ── PITCH LEGEND ── */
.pitch-legend{display:flex;flex-wrap:wrap;gap:4px;padding:4px 0;border-top:1px solid var(--border);}
.pl-item{display:flex;align-items:center;gap:3px;font-family:'DM Mono',monospace;font-size:.5rem;color:var(--sub)}
.pl-dot{width:7px;height:7px;border-radius:50%;flex-shrink:0}

/* ── TOOLTIP ── */
.tip{
  position:fixed;background:rgba(8,10,18,.97);border:1px solid var(--border);
  border-radius:5px;padding:7px 10px;font-size:.72rem;pointer-events:none;
  z-index:500;display:none;line-height:1.8;min-width:140px;
  font-family:'DM Mono',monospace;
}

/* ── EMPTY STATE ── */
.empty{display:flex;align-items:center;justify-content:center;height:100%;flex-direction:column;gap:8px;color:var(--sub);font-family:'DM Mono',monospace;font-size:.7rem;letter-spacing:.06em}
.empty-icon{font-size:2.5rem;opacity:.2}
</style>
</head>
<body>
<header>
  <div class="logo">LAK 2026</div>
  <span class="badge">AT-BAT VIEWER</span>
  <div class="hdr-right">13 batters · May 14–31 · pitcher POV</div>
</header>
<div class="layout">
  <div class="sidebar">
    <div class="sb-label">Batter</div>
    <div class="batter-list" id="batterList"></div>
  </div>
  <div class="main">
    <div class="game-tabs" id="gameTabs"></div>
    <div class="ab-scroll" id="abScroll">
      <div class="empty"><div class="empty-icon">⚾</div><div>Select a batter</div></div>
    </div>
  </div>
</div>
<div class="tip" id="tip"></div>

<script>
const RAW_B64 = "";
const INDEX = {"Blomgren, Jack":["May 15 \u2014 WisconsinBrewingCompany","May 16 \u2014 WisconsinBrewingCompany","May 19 \u2014 SiouxFalls","May 20 \u2014 SiouxFalls","May 21 \u2014 SiouxFalls","May 22 \u2014 Legends","May 24 \u2014 Legends","May 26 \u2014 NewmanOutdoor","May 27 \u2014 NewmanOutdoor","May 28 \u2014 NewmanOutdoor","May 29 \u2014 WisconsinBrewingCompany","May 31 \u2014 WisconsinBrewingCompany"],"Carreras, Julio":["May 15 \u2014 WisconsinBrewingCompany","May 16 \u2014 WisconsinBrewingCompany","May 17 \u2014 WisconsinBrewingCompany","May 19 \u2014 SiouxFalls","May 20 \u2014 SiouxFalls","May 21 \u2014 SiouxFalls","May 22 \u2014 Legends","May 23 \u2014 Legends","May 24 \u2014 Legends","May 26 \u2014 NewmanOutdoor","May 27 \u2014 NewmanOutdoor","May 28 \u2014 NewmanOutdoor","May 29 \u2014 WisconsinBrewingCompany","May 30 \u2014 WisconsinBrewingCompany","May 31 \u2014 WisconsinBrewingCompany"],"Dirksen, Drey":["May 20 \u2014 SiouxFalls","May 22 \u2014 Legends","May 24 \u2014 Legends","May 28 \u2014 NewmanOutdoor","May 31 \u2014 WisconsinBrewingCompany"],"Feliciano, Mario":["May 19 \u2014 SiouxFalls","May 21 \u2014 SiouxFalls","May 22 \u2014 Legends","May 23 \u2014 Legends","May 26 \u2014 NewmanOutdoor","May 27 \u2014 NewmanOutdoor","May 29 \u2014 WisconsinBrewingCompany","May 30 \u2014 WisconsinBrewingCompany"],"Hernandez, Ryan":["May 15 \u2014 WisconsinBrewingCompany","May 16 \u2014 WisconsinBrewingCompany","May 17 \u2014 WisconsinBrewingCompany","May 19 \u2014 SiouxFalls","May 20 \u2014 SiouxFalls","May 21 \u2014 SiouxFalls","May 22 \u2014 Legends","May 23 \u2014 Legends","May 24 \u2014 Legends","May 28 \u2014 NewmanOutdoor","May 29 \u2014 WisconsinBrewingCompany","May 30 \u2014 WisconsinBrewingCompany","May 31 \u2014 WisconsinBrewingCompany"],"Johnson, Dom":["May 15 \u2014 WisconsinBrewingCompany","May 16 \u2014 WisconsinBrewingCompany","May 17 \u2014 WisconsinBrewingCompany","May 19 \u2014 SiouxFalls","May 20 \u2014 SiouxFalls","May 21 \u2014 SiouxFalls","May 22 \u2014 Legends","May 23 \u2014 Legends","May 24 \u2014 Legends","May 26 \u2014 NewmanOutdoor","May 27 \u2014 NewmanOutdoor","May 28 \u2014 NewmanOutdoor","May 29 \u2014 WisconsinBrewingCompany","May 30 \u2014 WisconsinBrewingCompany","May 31 \u2014 WisconsinBrewingCompany"],"Lee, Ryan":["May 16 \u2014 WisconsinBrewingCompany","May 17 \u2014 WisconsinBrewingCompany"],"Mears, Joshua":["May 15 \u2014 WisconsinBrewingCompany","May 16 \u2014 WisconsinBrewingCompany","May 17 \u2014 WisconsinBrewingCompany","May 19 \u2014 SiouxFalls","May 20 \u2014 SiouxFalls","May 21 \u2014 SiouxFalls","May 23 \u2014 Legends","May 24 \u2014 Legends","May 26 \u2014 NewmanOutdoor","May 27 \u2014 NewmanOutdoor","May 28 \u2014 NewmanOutdoor","May 29 \u2014 WisconsinBrewingCompany","May 30 \u2014 WisconsinBrewingCompany"],"Nelson, Mat":["May 15 \u2014 WisconsinBrewingCompany","May 16 \u2014 WisconsinBrewingCompany"],"Reyes, Ripken":["May 15 \u2014 WisconsinBrewingCompany","May 16 \u2014 WisconsinBrewingCompany","May 17 \u2014 WisconsinBrewingCompany","May 19 \u2014 SiouxFalls","May 20 \u2014 SiouxFalls","May 21 \u2014 SiouxFalls","May 22 \u2014 Legends","May 23 \u2014 Legends","May 24 \u2014 Legends","May 26 \u2014 NewmanOutdoor","May 27 \u2014 NewmanOutdoor","May 28 \u2014 NewmanOutdoor","May 29 \u2014 WisconsinBrewingCompany","May 30 \u2014 WisconsinBrewingCompany","May 31 \u2014 WisconsinBrewingCompany"],"Roberts, Brett":["May 16 \u2014 WisconsinBrewingCompany","May 17 \u2014 WisconsinBrewingCompany","May 19 \u2014 SiouxFalls","May 22 \u2014 Legends","May 23 \u2014 Legends","May 26 \u2014 NewmanOutdoor","May 27 \u2014 NewmanOutdoor","May 29 \u2014 WisconsinBrewingCompany","May 30 \u2014 WisconsinBrewingCompany","May 31 \u2014 WisconsinBrewingCompany"],"Zimmermann, Peter":["May 15 \u2014 WisconsinBrewingCompany","May 16 \u2014 WisconsinBrewingCompany","May 17 \u2014 WisconsinBrewingCompany","May 19 \u2014 SiouxFalls","May 20 \u2014 SiouxFalls","May 21 \u2014 SiouxFalls","May 23 \u2014 Legends","May 24 \u2014 Legends","May 26 \u2014 NewmanOutdoor","May 27 \u2014 NewmanOutdoor","May 28 \u2014 NewmanOutdoor","May 29 \u2014 WisconsinBrewingCompany","May 30 \u2014 WisconsinBrewingCompany","May 31 \u2014 WisconsinBrewingCompany"],"Zuberer, Ray":["May 15 \u2014 WisconsinBrewingCompany","May 17 \u2014 WisconsinBrewingCompany","May 20 \u2014 SiouxFalls","May 21 \u2014 SiouxFalls","May 22 \u2014 Legends","May 23 \u2014 Legends","May 24 \u2014 Legends","May 26 \u2014 NewmanOutdoor","May 27 \u2014 NewmanOutdoor","May 28 \u2014 NewmanOutdoor","May 30 \u2014 WisconsinBrewingCompany","May 31 \u2014 WisconsinBrewingCompany"]};

const PITCH_COLORS = {
  'Four-Seam':'#ef4444','Sinker':'#f97316','Cutter':'#eab308',
  'Slider':'#3b82f6','Curveball':'#a855f7','Changeup':'#22c55e',
  'Splitter':'#06b6d4','Sweeper':'#0097A7','Undefined':'#6a728a',
};
const PITCH_ABBR = {
  'Four-Seam':'FF','Sinker':'SI','Cutter':'CT','Slider':'SL',
  'Curveball':'CU','Changeup':'CH','Splitter':'FS','Sweeper':'SW','Undefined':'?',
};
const CALL_COLORS = {
  'StrikeCalled':'#f87171','StrikeSwinging':'#f97316',
  'FoulBallFieldable':'#fbbf24','FoulBallNotFieldable':'#fbbf24',
  'BallCalled':'#60a5fa','BallIntentional':'#60a5fa','BallinDirt':'#60a5fa',
  'InPlay':'#4ade80','HitByPitch':'#e879f9',
};

// Decompress
let DATA = null;
function loadData(){
  const bin=atob(RAW_B64);
  const bytes=new Uint8Array(bin.length);
  for(let i=0;i<bin.length;i++) bytes[i]=bin.charCodeAt(i);
  DATA=JSON.parse(pako.inflate(bytes,{to:'string'}));
}

let selBatter='', selGame='';
const tip=document.getElementById('tip');
const gameTabs=document.getElementById('gameTabs');
const abScroll=document.getElementById('abScroll');
const batterList=document.getElementById('batterList');

// Build batter list
Object.keys(INDEX).sort().forEach(b=>{
  const btn=document.createElement('button');
  btn.className='bb'; btn.textContent=b.split(',')[0]+', '+b.split(',')[1]?.trim()[0]+'.';
  btn.dataset.full=b;
  btn.addEventListener('click',()=>selectBatter(b));
  batterList.appendChild(btn);
});

function selectBatter(b){
  if(!DATA) loadData();
  selBatter=b;
  batterList.querySelectorAll('.bb').forEach(btn=>btn.classList.toggle('active',btn.dataset.full===b));
  const games=INDEX[b]||[];
  selGame=games[0]||'';
  buildGameTabs(games);
  renderABs();
}

function buildGameTabs(games){
  gameTabs.innerHTML='';
  games.forEach(g=>{
    const btn=document.createElement('button');
    btn.className='gt'+(g===selGame?' active':'');
    btn.textContent=g;
    btn.addEventListener('click',()=>{
      selGame=g;
      gameTabs.querySelectorAll('.gt').forEach(b=>b.classList.toggle('active',b.textContent===g));
      renderABs();
    });
    gameTabs.appendChild(btn);
  });
}

function resultClass(result){
  if(result==='Home Run') return 'hr';
  if(['Single','Double','Triple','Reached on Error','Hit By Pitch',"Fielder's Choice"].includes(result)) return 'hit';
  if(['Strikeout Looking','Strikeout Swinging'].includes(result)) return 'k';
  if(['Walk','Intentional Walk'].includes(result)) return 'bb';
  return 'out';
}

function resultCardClass(result){
  if(result==='Home Run') return 'result-hr';
  if(['Single','Double','Triple','Reached on Error','Hit By Pitch'].includes(result)) return 'result-hit';
  if(['Strikeout Looking','Strikeout Swinging'].includes(result)) return 'result-k';
  if(['Walk','Intentional Walk'].includes(result)) return 'result-bb';
  return '';
}

// ── STRIKE ZONE DRAW ─────────────────────────────────────────────
const SZL=-0.7083,SZR=0.7083,SZB=1.5,SZT=3.5;
const XMIN=-2.0,XMAX=2.0,YMIN=0.5,YMAX=4.5;
const CW=148,CH=158;

function toCanvas(x,y){
  const cx=((x-XMIN)/(XMAX-XMIN))*CW;
  const cy=(1-(y-YMIN)/(YMAX-YMIN))*CH;
  return [cx,cy];
}

function drawSZ(canvas, pitches){
  canvas.width=CW; canvas.height=CH;
  const ctx=canvas.getContext('2d');
  ctx.fillStyle='#0b0d12'; ctx.fillRect(0,0,CW,CH);

  // Strike zone
  const [szlx]=toCanvas(SZL,SZT);
  const [szrx,szty]=toCanvas(SZR,SZT);
  const [,szby]=toCanvas(SZL,SZB);
  ctx.strokeStyle='rgba(255,255,255,0.55)'; ctx.lineWidth=1.5;
  ctx.strokeRect(szlx,szty,szrx-szlx,szby-szty);

  // 9-zone grid
  const zw=(szrx-szlx)/3, zh=(szby-szty)/3;
  ctx.strokeStyle='rgba(255,255,255,0.12)'; ctx.lineWidth=0.5;
  for(let i=1;i<3;i++){
    ctx.beginPath();ctx.moveTo(szlx+zw*i,szty);ctx.lineTo(szlx+zw*i,szby);ctx.stroke();
    ctx.beginPath();ctx.moveTo(szlx,szty+zh*i);ctx.lineTo(szrx,szty+zh*i);ctx.stroke();
  }

  // Home plate hint
  ctx.strokeStyle='rgba(255,255,255,0.2)'; ctx.lineWidth=1;
  ctx.beginPath();ctx.moveTo(szlx,CH-4);ctx.lineTo(szrx,CH-4);ctx.stroke();

  // Pitches
  pitches.forEach((p,i)=>{
    if(p.x===null||p.y===null) return;
    const [cx,cy]=toCanvas(p.x,p.y);
    const col=PITCH_COLORS[p.pt]||'#888';
    const callCol=CALL_COLORS[p.call]||'rgba(255,255,255,.4)';

    // Shadow
    ctx.shadowColor=col+'88'; ctx.shadowBlur=6;
    ctx.fillStyle=col; ctx.globalAlpha=0.9;
    ctx.beginPath();ctx.arc(cx,cy,6.5,0,Math.PI*2);ctx.fill();
    ctx.shadowBlur=0; ctx.globalAlpha=1;

    // Ring for non-swing strikes and balls
    if(p.call==='StrikeCalled'){
      ctx.strokeStyle='rgba(248,113,113,.8)'; ctx.lineWidth=1.5;
      ctx.beginPath();ctx.arc(cx,cy,8,0,Math.PI*2);ctx.stroke();
    } else if(p.call==='InPlay'){
      ctx.strokeStyle='rgba(74,222,128,.9)'; ctx.lineWidth=2;
      ctx.beginPath();ctx.arc(cx,cy,8.5,0,Math.PI*2);ctx.stroke();
    } else if(p.call==='HitByPitch'){
      ctx.strokeStyle='rgba(232,121,249,.9)'; ctx.lineWidth=2;
      ctx.beginPath();ctx.arc(cx,cy,8.5,0,Math.PI*2);ctx.stroke();
    }

    // Sequence number
    ctx.fillStyle='#fff'; ctx.font='bold 7px DM Mono,monospace'; ctx.textAlign='center';
    ctx.fillText(i+1,cx,cy+2.5);
  });
}

// ── RENDER ABS ───────────────────────────────────────────────────
function renderABs(){
  if(!selBatter||!selGame){
    abScroll.innerHTML='<div class="empty"><div class="empty-icon">⚾</div><div>Select a batter</div></div>';
    return;
  }
  const pas=DATA[selBatter]?.[selGame]||[];
  if(!pas.length){
    abScroll.innerHTML='<div class="empty"><div class="empty-icon">—</div><div>No data for this game</div></div>';
    return;
  }

  const grid=document.createElement('div');
  grid.className='ab-grid';

  // Collect which pitch types appear
  const ptSeen=new Set();
  pas.forEach(pa=>pa.pitches.forEach(p=>ptSeen.add(p.pt)));

  pas.forEach((pa,idx)=>{
    const rc=resultClass(pa.result);
    const card=document.createElement('div');
    card.className='ab-card '+resultCardClass(pa.result);

    // Header: inning + pitch count
    const hdr=document.createElement('div');
    hdr.className='ab-header';
    const innLabel='Inn '+pa.inn+(pa.bot==='Bottom'?' ▼':' ▲');
    hdr.innerHTML=`<span class="ab-inn">${innLabel}</span><span class="ab-pc">${pa.pitches.length}p</span>`;
    card.appendChild(hdr);

    // Pitcher line
    const pitcherDiv=document.createElement('div');
    pitcherDiv.className='ab-pitcher';
    const throwClass=pa.throws==='Right'?'throws-R':'throws-L';
    pitcherDiv.innerHTML=`<span class="${throwClass}">${pa.throws==='Right'?'RHP':'LHP'}</span><span>${pa.pitcher?pa.pitcher.split(',')[0]:'—'}</span>`;
    card.appendChild(pitcherDiv);

    // Canvas
    const cv=document.createElement('canvas');
    cv.className='sz';
    card.appendChild(cv);
    drawSZ(cv, pa.pitches);

    // Tooltip on hover
    cv.addEventListener('mousemove',e=>{
      const rect=cv.getBoundingClientRect();
      const scaleX=CW/rect.width, scaleY=CH/rect.height;
      const mx=(e.clientX-rect.left)*scaleX;
      const my=(e.clientY-rect.top)*scaleY;
      let found=null, minD=100;
      pa.pitches.forEach((p,i)=>{
        if(p.x===null||p.y===null) return;
        const [px,py]=toCanvas(p.x,p.y);
        const d=Math.sqrt((mx-px)**2+(my-py)**2);
        if(d<minD){minD=d;found={p,i};}
      });
      if(found&&minD<14){
        const {p,i}=found;
        const cnt=`${p.balls}-${p.strikes}`;
        const velo=p.velo?`${p.velo.toFixed(1)} mph`:'—';
        const callLabel=p.call.replace(/([A-Z])/g,' $1').trim();
        const col=PITCH_COLORS[p.pt]||'#888';
        tip.innerHTML=`<span style="color:${col};font-weight:600">${p.pt}</span> · ${velo}<br>Count: ${cnt} · Pitch ${i+1}<br><span style="color:${CALL_COLORS[p.call]||'#aaa'}">${callLabel}</span>`;
        tip.style.display='block';
        tip.style.left=(e.clientX+12)+'px';
        tip.style.top=(e.clientY-10)+'px';
      } else {
        tip.style.display='none';
      }
    });
    cv.addEventListener('mouseleave',()=>tip.style.display='none');

    // Result chip
    const resultDiv=document.createElement('div');
    resultDiv.className=`result-chip ${rc}`;
    resultDiv.textContent=pa.result;
    card.appendChild(resultDiv);

    // BIP stats
    const hasBIP=['Single','Double','Triple','Home Run','Out','Sacrifice',"Fielder's Choice",'Reached on Error'].includes(pa.result);
    if(hasBIP&&(pa.ev||pa.la||pa.dist)){
      const bipDiv=document.createElement('div');
      bipDiv.className='bip-stats';
      if(pa.ev){
        const evClass=pa.ev>=100?'bip-stat ev-hot':pa.ev>=90?'bip-stat ev-warm':'bip-stat';
        bipDiv.innerHTML+=`<span class="${evClass}">EV <b>${pa.ev}</b> mph</span>`;
      }
      if(pa.la!==null&&pa.la!==undefined){
        bipDiv.innerHTML+=`<span class="bip-stat">LA <b>${pa.la}°</b></span>`;
      }
      if(pa.result==='Home Run'&&pa.dist){
        bipDiv.innerHTML+=`<span class="bip-stat" style="color:var(--accent)"><b>${Math.round(pa.dist)} ft</b></span>`;
      }
      if(pa.ht&&pa.ht!=='Undefined'){
        const htAbbr={'GroundBall':'GB','LineDrive':'LD','FlyBall':'FB','Popup':'PU','Bunt':'BT'};
        bipDiv.innerHTML+=`<span class="bip-stat"><b>${htAbbr[pa.ht]||pa.ht}</b></span>`;
      }
      card.appendChild(bipDiv);
    }

    grid.appendChild(card);
  });

  // Pitch legend at bottom
  const legendDiv=document.createElement('div');
  legendDiv.style.cssText='width:100%;display:flex;flex-wrap:wrap;gap:8px;padding:12px 0 0;border-top:1px solid var(--border);margin-top:4px;font-family:DM Mono,monospace;font-size:.58rem;color:var(--sub)';

  // Call legend
  [['FF','StrikeCalled','rgba(248,113,113,.8)','Called Strike'],
   ['SW','StrikeSwinging','#f97316','Swinging Strike'],
   ['F','FoulBallFieldable','#fbbf24','Foul'],
   ['B','BallCalled','#60a5fa','Ball'],
   ['IP','InPlay','rgba(74,222,128,.9)','In Play'],
  ].forEach(([,call,col,label])=>{
    const li=document.createElement('div');li.style.cssText='display:flex;align-items:center;gap:4px';
    li.innerHTML=`<div style="width:9px;height:9px;border-radius:50%;background:${col}"></div><span>${label}</span>`;
    legendDiv.appendChild(li);
  });

  const wrap=document.createElement('div');
  wrap.style.cssText='width:100%';
  wrap.appendChild(grid);
  wrap.appendChild(legendDiv);
  abScroll.innerHTML='';
  abScroll.appendChild(wrap);
}
</script>
</body>
</html>
